PORT=5000
MONGO_URI=mongodb://localhost:27017/taskMate
JWT_SECRET=your_jwt_secret_here
CLIENT_URL=http://localhost:5173

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=skip
CLOUDINARY_API_KEY=skip
CLOUDINARY_API_SECRET=skip

# Razorpay (for payments) — set to real keys to enable, or leave as 'skip' for mock mode
RAZORPAY_KEY_ID=skip
RAZORPAY_KEY_SECRET=skip

# Clerk (authentication) — REQUIRED
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
